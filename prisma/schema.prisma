// Velocidad — Pompeyo Carrasco
// Stack: PostgreSQL (Railway) + Prisma + NextAuth v5 (JWT strategy)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USUARIOS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  rol          Rol      @default(JEFE_MARCA)
  activo       Boolean  @default(true)
  telefono     String?  // WhatsApp (+56912345678) — usado por el agente
  marcas       String[] // marcas que gestiona este usuario (ej: ["KIA MOTORS","MG"])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  snapshots          Snapshot[]
  gestiones          GestionVIN[]
  alertaLogs         AlertaLog[]
  alertaConfs        AlertaConfig[]
  historicoArchivos  SnapshotHistoricoArchivo[]
  tareasAsignadas    TareaOperacional[] @relation("TareasAsignadas")
  tareasCreadas      TareaOperacional[] @relation("TareasCreadas")
}

enum Rol {
  ADMIN           // sube KPIs, gestión de usuarios, acceso total
  DIRECTOR        // análisis genérico, solo lectura, ve todas las marcas
  GERENTE_GENERAL // gestión integral, gestiona usuarios, ve todas las marcas
  GERENTE         // responsable de indicadores, ve solo sus marcas asignadas
  JEFE_MARCA      // responsable operacional, ve solo sus marcas asignadas
}

// ─────────────────────────────────────────────
// SNAPSHOTS — Excel parseado y guardado en DB
// Así todos ven los mismos datos sin re-subir el archivo.
// Solo un snapshot por fuente puede estar activo a la vez.
// ─────────────────────────────────────────────

model Snapshot {
  id         String    @id @default(cuid())
  nombre     String    // nombre del archivo original
  tamano     Int       // bytes del archivo original
  fechaCorte DateTime? // fecha de corte declarada en el Excel
  fuente     Fuente    // qué tipo de dato contiene
  payload    Json      // datos parseados (ParsedExcel, ParsedFNE, etc.)
  registros  Int       @default(0) // cantidad de registros (vehículos, filas, etc.)
  activo     Boolean   @default(false) // solo uno activo por fuente
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([fuente, activo])
}

enum Fuente {
  BASE_STOCK      // Excel maestro de stock semanal
  FNE             // Autos no entregados
  SALDOS          // Reportes Saldos 2.0
  PROVISIONES     // Provisiones
  LOGISTICA_ROMA  // Agenda proveedor ROMA
  LOGISTICA_STLI  // Ejecución bodega STLI
}

// ─────────────────────────────────────────────
// GESTIÓN DE CASOS POR VIN
// Migración de localStorage → DB multiusuario.
// Un registro por VIN. El historial se guarda aparte.
// ─────────────────────────────────────────────

model GestionVIN {
  id               String          @id @default(cuid())
  vin              String          @unique
  comentario       String?         // contexto / blocker actual
  proximaAccion    String?         // acción concreta a ejecutar
  responsable      String?         // nombre del responsable
  responsableEmail String?         // email para notificaciones futuras
  ownership        String?         // quién creó/posee el caso
  fechaCompromiso  DateTime?       // deadline comprometido
  estadoGestion    EstadoGestion   @default(ABIERTO)
  prioridadManual  PrioridadManual?
  userId           String?         // último usuario que editó
  user             User?           @relation(fields: [userId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  historial HistorialGestion[]

  @@index([estadoGestion])
  @@index([prioridadManual])
}

enum EstadoGestion {
  ABIERTO
  EN_CURSO
  ESPERANDO
  RESUELTO
  CANCELADO
}

enum PrioridadManual {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

// ─────────────────────────────────────────────
// HISTORIAL DE GESTIÓN — auditoría append-only
// Cap de 50 entradas por VIN (se purgan al guardar).
// ─────────────────────────────────────────────

model HistorialGestion {
  id            String     @id @default(cuid())
  gestionId     String
  gestion       GestionVIN @relation(fields: [gestionId], references: [id], onDelete: Cascade)
  campo         String     // campo que cambió
  valorAnterior String?
  valorNuevo    String?
  usuario       String?    // nombre del usuario que hizo el cambio
  userEmail     String?
  createdAt     DateTime   @default(now())

  @@index([gestionId])
}

// ─────────────────────────────────────────────
// AGENTE WHATSAPP — configuración y log de alertas
// ─────────────────────────────────────────────

model AlertaConfig {
  id          String     @id @default(cuid())
  tipo        AlertaTipo
  activo      Boolean    @default(true)
  horaEnvio   String     @default("08:00") // HH:MM hora Chile
  diasSemana  Int[]      @default([1, 2, 3, 4, 5]) // 1=lunes … 7=domingo
  userId      String?    // null = aplica a todos los usuarios con teléfono
  user        User?      @relation(fields: [userId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model AlertaLog {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  tipo      AlertaTipo
  vin       String?    // VIN relacionado (si aplica)
  mensaje   String     @db.Text // texto enviado
  enviado   Boolean    @default(false)
  errorMsg  String?    // mensaje de error si falló el envío
  waMsgId   String?    // ID del mensaje en WhatsApp
  /// Canal elegido al asignar: "WHATSAPP" | "EMAIL". Null = registros previos
  /// a la columna ("pendiente de canal"). El envío externo sigue simulado —
  /// la asignación interna es la obligatoria.
  canal     String?
  /// Tarea operacional que originó esta alerta (solo tipo TAREA_ASIGNADA).
  tareaId   String?
  tarea     TareaOperacional? @relation(fields: [tareaId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())

  // ── F2 · Estado real de entrega en Meta WhatsApp Cloud API ──
  /// Ciclo de vida del envío: sending → accepted → sent → delivered → read,
  /// o failed. Null = aún no se intentó por WhatsApp. OJO: `enviado=true` solo
  /// significa "aceptado por Meta"; la verdad de entrega vive en waStatus.
  waStatus     String?
  waStatusAt   DateTime? // timestamp del último cambio de estado
  waErrorCode  Int?      // código de error de Meta (ej. 131047 = fuera de ventana 24h)
  waErrorTitle String?   // título/tipo del error de Meta
  /// Auditoría cruda: { request, response, lastStatus } del envío y los webhooks.
  waRaw        Json?

  @@index([userId])
  @@index([createdAt])
  @@index([tipo, enviado])
  @@index([waMsgId]) // el webhook de status actualiza por waMsgId
}

enum AlertaTipo {
  BRIEFING_DIARIO
  FECHA_COMPROMISO_VENCIDA
  CASO_SIN_MOVIMIENTO
  PRIORIDAD_CRITICA
  MENSAJE_ENTRANTE
  TAREA_ASIGNADA
}

// ═════════════════════════════════════════════════════════════════════
// TAREAS OPERACIONALES — asignación de trabajo por caso
//
// Una tarea = unidad de trabajo asignada a un usuario sobre un caso
// gestionable (VIN o clave documental SALDO-/BONO-/PROV-). N tareas por
// caso. NO reemplaza GestionVIN (que sigue siendo el estado 1:1 del
// caso) — lo complementa.
//
// La notificación de la asignación se registra como AlertaLog con tipo
// TAREA_ASIGNADA y enviado=false. En F1 el envío es manual (panel
// /notificaciones · copiar mensaje + marcar enviada). En F2 César
// procesará las pendientes vía su cron + whatsapp.py.
//
// Snapshot del caso (vin/patente/marca/modelo) congelado al crear:
// el mensaje histórico no muta si la base cambia después.
// ═════════════════════════════════════════════════════════════════════

model TareaOperacional {
  id              String      @id @default(cuid())
  /// VIN limpio · o clave documental (SALDO-…, BONO-…, PROV-…).
  claveCaso       String
  /// "vin" | "saldo" | "bono" | "provision"
  tipoCaso        String      @default("vin")
  /// Texto libre del solicitante ("Por favor revisa este caso").
  mensaje         String      @db.Text
  /// Contexto del caso ("Auto pagado pendiente de gestión").
  motivo          String?
  // ── Snapshot del caso al momento de crear ──
  vin             String?
  patente         String?
  marca           String?
  modelo          String?
  // ── Asignación ──
  asignadoId      String
  asignado        User        @relation("TareasAsignadas", fields: [asignadoId], references: [id])
  creadorId       String
  creador         User        @relation("TareasCreadas", fields: [creadorId], references: [id])
  estado          EstadoTarea @default(PENDIENTE)
  fechaCompromiso DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  alertas         AlertaLog[]

  @@index([asignadoId, estado])
  @@index([claveCaso])
}

enum EstadoTarea {
  PENDIENTE
  EN_CURSO
  COMPLETADA
  CANCELADA
}

// ═════════════════════════════════════════════════════════════════════
// MOTOR HISTÓRICO DE SNAPSHOTS — Velocity Operating System
//
// Capa SEPARADA del snapshot vivo. El motor histórico es la MEMORIA
// VIVA del sistema: cada carga operacional relevante deja una huella
// que después permite ver si el negocio mejora o empeora en velocidad,
// cumplimiento, capital, stock, entrega y disciplina gerencial.
//
// Dos modelos, dos comportamientos:
//
//   A) SnapshotHistoricoArchivo — INMUTABLE
//      Registro inmutable de cada Excel cargado. Una fila por
//      (fuente, snapshotDate, hashSha256). Auditoría pura.
//
//   B) OperationalSnapshot — UPSERT mientras esté draft
//      Foto consolidada mensual del Velocity OS. Una fila por
//      (snapshotPeriod, snapshotType). Se va completando con cada
//      fuente nueva que llega del mismo período. Al cerrar el mes
//      pasa a `status = closed` y queda inmutable. Correcciones
//      posteriores se persisten como nuevo snapshotType="correction".
//
// Reglas (decisión usuario 2026-06):
//   · La fecha de corte canónica se DERIVA: archivos de días 01-03
//     se interpretan como cierre del mes anterior (regla "Informe
//     02-Marzo = cierre Febrero").
//   · Construcción orgánica — no hay backfill obligatorio. El motor
//     se llena mes a mes con cada cierre operacional.
//   · Series parciales aceptadas — si falta FNE o Provisiones de un
//     mes, esos campos quedan null. NO se inventa ni se interpola.
//   · Recálculo seguro — si un selector falla durante la consolidación,
//     se guarda warning y se persiste lo que sí se pudo calcular.
// ═════════════════════════════════════════════════════════════════════

model SnapshotHistoricoArchivo {
  id                  String   @id @default(cuid())
  fuente              Fuente
  /// Fecha de corte CANÓNICA derivada (último día del mes representado).
  snapshotDate        DateTime
  /// "2026-02", "2026-03" — facilita queries por mes.
  snapshotPeriod      String
  nombreOriginal      String
  hashSha256          String
  tamano              Int
  /// Fecha que dice el archivo internamente (raw, antes de derivar).
  fechaCorteDeclarada DateTime?
  /// Fecha que detectó el parser interno.
  fechaCorteDetectada DateTime?
  /// Origen de la fechaCorte: "excel" (parser) | "filename" | "fallback" | "manual".
  fuenteFechaCorte    String   @default("excel")
  /// true cuando el archivo califica como cierre mensual (prioridad >= 70).
  esCierreMensual     Boolean  @default(false)
  /// Prioridad 0-100. Determina qué archivo "gana" los KPIs cuando hay
  /// múltiples archivos de la misma fuente para el mismo período.
  /// Regla: el archivo con mayor prioridadCierre escribe los KPIs.
  /// Un corte intermedio (08-May, prioridad ~40) NO pisa el cierre real
  /// (31-May, prioridad >= 90).
  prioridadCierre     Int      @default(0)
  /// "ok" | "parcial" | "error"
  parseStatus         String   @default("ok")
  warnings            String[] @default([])
  /// "ingesta" | "backfill" | "manual"
  origenDeteccion     String   @default("ingesta")
  /// Payload parseado opcional (solo si necesario para auditoría).
  payload             Json?
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  createdAt           DateTime @default(now())

  /// Único por contenido — dos archivos con el mismo hash NO duplican,
  /// pero un mismo período puede tener varios archivos (corrección).
  @@unique([fuente, snapshotDate, hashSha256])
  @@index([snapshotPeriod])
  @@index([snapshotDate])
  @@index([hashSha256])
  @@index([fuente, snapshotPeriod, prioridadCierre])
}

model OperationalSnapshot {
  id                   String   @id @default(cuid())
  /// Último día del mes representado.
  snapshotDate         DateTime
  /// "2026-02", "2026-03" — identificador del período.
  snapshotPeriod       String
  /// "monthly" | "interim" | "correction" | "manual"
  snapshotType         String   @default("monthly")

  // ── ESTADO DEL SNAPSHOT ──────────────────────────────────────────
  /// "draft" | "closed". Draft = se puede actualizar con nuevas
  /// fuentes del mismo período. Closed = inmutable.
  status               String   @default("draft")
  /// Incremento cada vez que el snapshot se actualiza (audit trail).
  version              Int      @default(1)
  /// Última vez que se recalcularon los KPIs.
  lastRecalculatedAt   DateTime?
  /// Cuándo se cerró el período (null si está draft).
  closedAt             DateTime?
  closedByUserId       String?

  // ── TRAZABILIDAD ─────────────────────────────────────────────────
  sourceFiles          String[] @default([])  // nombres originales
  sourceHashes         String[] @default([])  // hashes SHA-256
  fuentesUsadas        String[] @default([])  // ["BASE_STOCK","SALDOS","FNE","PROVISIONES"]
  /// Fuentes que se esperan para considerar el snapshot completo.
  fuentesEsperadas     String[] @default(["BASE_STOCK", "SALDOS", "FNE", "PROVISIONES"])
  /// 0-100. fuentesUsadas.length / fuentesEsperadas.length * 100.
  completionPct        Int      @default(0)
  warnings             String[] @default([])

  // ── STOCK ────────────────────────────────────────────────────────
  stockUnidades         Int?
  stockMontoTotal       Decimal? @db.Decimal(18, 2)
  stockPagadoMonto      Decimal? @db.Decimal(18, 2)
  stockFinanciadoMonto  Decimal? @db.Decimal(18, 2)

  // ── LÍNEAS DE CRÉDITO ────────────────────────────────────────────
  lineaAutorizada      Decimal? @db.Decimal(18, 2)
  lineaUtilizada       Decimal? @db.Decimal(18, 2)
  lineaDisponible      Decimal? @db.Decimal(18, 2)
  lineaUtilizacionPct  Decimal? @db.Decimal(5, 2)

  // ── CAPITAL DE TRABAJO ───────────────────────────────────────────
  capitalTrabajoTotal      Decimal? @db.Decimal(18, 2)
  capitalTrabajoUtilizado  Decimal? @db.Decimal(18, 2)
  capitalTrabajoDisponible Decimal? @db.Decimal(18, 2)

  // ── FNE ──────────────────────────────────────────────────────────
  fneUnidades              Int?
  fneMonto                 Decimal? @db.Decimal(18, 2)
  fneDiasPromedio          Decimal? @db.Decimal(8, 2)
  fneListosEntrega         Int?
  fneBloqueadosCp          Int?
  fneBloqueadosInscripcion Int?
  fneBloqueadosLogistica   Int?
  fneBloqueadosComercial   Int?

  // ── CRÉDITO POMPEYO ──────────────────────────────────────────────
  creditoPompeyoMonto Decimal? @db.Decimal(18, 2)
  creditoPompeyoCasos Int?

  // ── SALDOS ───────────────────────────────────────────────────────
  saldosMontoTotal     Decimal? @db.Decimal(18, 2)
  saldosVehiculoMonto  Decimal? @db.Decimal(18, 2)
  saldosBonosMonto     Decimal? @db.Decimal(18, 2)
  saldosServiciosMonto Decimal? @db.Decimal(18, 2)

  // ── PROVISIONES ──────────────────────────────────────────────────
  provisionesTotalMonto           Decimal? @db.Decimal(18, 2)
  provisionesNoFacturadasMonto    Decimal? @db.Decimal(18, 2)
  provisionesNoFacturadasUnidades Int?

  // ── AGING (unidades + monto · 6 buckets) ─────────────────────────
  aging0_30Unidades    Int?
  aging31_60Unidades   Int?
  aging61_90Unidades   Int?
  aging91_120Unidades  Int?
  aging121_180Unidades Int?
  aging180MasUnidades  Int?
  aging0_30Monto       Decimal? @db.Decimal(18, 2)
  aging31_60Monto      Decimal? @db.Decimal(18, 2)
  aging61_90Monto      Decimal? @db.Decimal(18, 2)
  aging91_120Monto     Decimal? @db.Decimal(18, 2)
  aging121_180Monto    Decimal? @db.Decimal(18, 2)
  aging180MasMonto     Decimal? @db.Decimal(18, 2)

  // ── SCORES (0-100) ───────────────────────────────────────────────
  scoreGerencial    Int?
  scoreOperacional  Int?
  scoreCumplimiento Int?
  scoreVelocidad    Int?
  scoreCapital      Int?

  // ── CUMPLIMIENTO ─────────────────────────────────────────────────
  cumplimientoGlobalPct         Decimal? @db.Decimal(5, 2)
  cumplimientoComercialPct      Decimal? @db.Decimal(5, 2)
  cumplimientoControlNegocioPct Decimal? @db.Decimal(5, 2)
  cumplimientoLogisticaPct      Decimal? @db.Decimal(5, 2)
  cumplimientoSucursalPct       Decimal? @db.Decimal(5, 2)

  // ── ALERTAS ──────────────────────────────────────────────────────
  alertasCriticas Int?
  alertasAltas    Int?
  alertasMedias   Int?

  // ── BRECHAS ──────────────────────────────────────────────────────
  responsablesConAtrasos Int?
  sucursalesConBrechas   Int?
  marcasConBrechas       Int?

  // ── COMPONENTES DE SCORES (1b) ───────────────────────────────────
  // JSON flexible con la descomposición de cada score por indicador,
  // metadata Venn de bloqueos FNE, lista de marcas bajo umbral, y
  // warnings de cálculo. Permite explicar variaciones sin recalcular.
  // Shape documentado en src/lib/historico/score-componentes.ts.
  scoreComponentes Json?

  // ── AUDITORÍA ────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Un snapshot por período + tipo. Correcciones se crean con
  /// snapshotType = "correction" para no pisar el cerrado.
  @@unique([snapshotPeriod, snapshotType])
  @@index([snapshotDate])
  @@index([snapshotPeriod])
  @@index([status])
}


// ─────────────────────────────────────────────────────────────────────
// Tendencias persistentes · snapshot diario del ESTADO VIGENTE
// ─────────────────────────────────────────────────────────────────────

enum ScopeSnapshotDiario {
  TOTAL
  MARCA
}

/// Foto diaria de "cómo estaba el sistema ese día" — NO de qué archivo se
/// cargó ese día. La genera un job diario (o la acción manual) leyendo los
/// Snapshot vigentes (activo: true) ya ingestados y normalizados por la app.
/// /tendencias lee esta tabla para la evolución diaria real hacia adelante.
model DailyCapitalSnapshot {
  id        String              @id @default(cuid())
  /// Día del snapshot en hora Chile, normalizado a 00:00 UTC (DATE).
  fecha     DateTime            @db.Date
  scopeTipo ScopeSnapshotDiario
  /// Marca canónica cuando scopeTipo = MARCA. "" para TOTAL — un string
  /// no-null permite que el unique [fecha, scopeTipo, marca] funcione
  /// para upsert (Postgres trata NULLs como distintos en uniques).
  marca     String              @default("")

  // ── Scores (0-100) ─────────────────────────────────────────────────
  /// Score Gerencial legacy (exige las 4 fuentes vigentes; null si falta alguna).
  scoreGerencial               Int?
  /// Reservados: se llenan cuando exista su motor de cálculo server-side.
  scoreCapital                 Int?
  scoreCumplimientoOperacional Int?
  scoreVelocidad               Int?

  // ── Componentes del capital de trabajo ─────────────────────────────
  // null = la fuente de ese componente no estaba vigente al generar.
  stockPagadoUnidades Int?
  stockPagadoMonto    Float?
  saldosUnidades      Int?
  saldosMonto         Float?
  bonosUnidades       Int?
  bonosMonto          Float?
  provisionesUnidades Int?
  provisionesMonto    Float?
  /// Suma de los montos presentes. null si ningún componente disponible.
  capitalTrabajoTotal Float?

  /// Fuentes vigentes usadas al generar:
  /// [{ fuente, etiqueta, presente, snapshotId, nombre, fechaCorte, cargadoEl }]
  cobertura Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Si el job corre dos veces el mismo día, actualiza — nunca duplica.
  @@unique([fecha, scopeTipo, marca])
  @@index([scopeTipo, marca, fecha])
}
